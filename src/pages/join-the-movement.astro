---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
import jwj2026Conference from '../assets/jwj_2026_conference.png';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout>
	<Fragment slot="head">
		<BaseHead title={`Join The Movement for Worker Justice - ${SITE_TITLE}`} description="Join Philadelphia's movement for worker justice. Be part of a labor-community coalition building people power, working class power, and solidarity. Get involved with organizer training, Power School, and collective action." keywords="join worker justice movement Philadelphia, people power, working class power, solidarity, labor-community coalition, Power School, organizer training program" />
		<style>
		main {
			width: 100% !important;
			max-width: 100% !important;
			margin: 0;
			padding: 0 !important;
			box-sizing: border-box;
		}
		.content {
			max-width: 720px;
			margin: 0 auto;
			padding: 1.5em 1em 2em;
		}
		main h2 {
			font-size: 1.5em;
			text-align: center;
			margin: 1.25em 0 0.5em;
			color: var(--deep-space-blue);
			position: relative;
			padding-bottom: 0.4em;
		}
		main h2:first-of-type {
			margin-top: 0.25em;
		}
		main h2::after {
			content: '';
			display: block;
			width: 60px;
			height: 3px;
			background: var(--sky-surge);
			margin: 0.4em auto 0;
			border-radius: 2px;
		}
		.buttons {
			display: flex;
			gap: 1em;
			flex-wrap: wrap;
			justify-content: center;
			margin: 0.5em 0;
		}
		.buttons.top-cta {
			margin: 1em 0 1.5em;
		}
		.buttons.full-width .btn {
			display: block;
			width: 100%;
			text-align: center;
			box-sizing: border-box;
		}
		.buttons.split-2 {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1em;
		}
		.buttons.split-2 .btn {
			text-align: center;
		}
		.btn {
			display: inline-block;
			padding: 0.9em 2em;
			background: var(--deep-space-blue);
			color: var(--white);
			text-decoration: none;
			border-radius: 6px;
			font-weight: 700;
			font-size: 1em;
			border: 2px solid var(--sky-surge);
			box-shadow: 0 4px 0 var(--sky-surge);
			transition: transform 0.2s, box-shadow 0.2s, background 0.2s, color 0.2s;
		}
		.btn:hover {
			transform: translateY(-2px);
			box-shadow: 0 6px 0 var(--sky-surge);
		}
		.btn-yellow {
			background: var(--canary-yellow);
			color: var(--deep-space-blue);
			border: 2px solid var(--deep-space-blue);
			box-shadow: 0 4px 0 var(--deep-space-blue);
		}
		.btn-yellow:hover {
			transform: translateY(-2px);
			box-shadow: 0 6px 0 var(--deep-space-blue) !important;
		}
		/* Events */
		.events-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1em;
			margin: 0.5em 0 1em;
		}
		.events-grid > .event-link,
		.events-grid > .event-image-link {
			min-height: 200px;
		}
		.events-grid > .event-link.full-row,
		.events-grid > .event-image-link.full-row,
		.events-grid > .calendar-cell {
			grid-column: 1 / -1;
		}
		.event-link {
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			text-align: center;
			padding: 1.25em;
			background: var(--deep-space-blue);
			color: var(--white);
			text-decoration: none;
			border-radius: 8px;
			font-weight: 700;
			font-size: 1em;
			transition: background 0.2s, transform 0.2s;
		}
		.event-link:hover {
			background: var(--sky-surge);
			color: var(--deep-space-blue);
			transform: translateY(-2px);
		}
		.event-link .event-sub {
			font-weight: 400;
			font-size: 0.85em;
			opacity: 0.85;
			display: block;
			margin-top: 0.3em;
		}
		.event-image-link {
			display: block;
			border-radius: 8px;
			overflow: hidden;
			transition: opacity 0.2s, transform 0.2s;
			min-height: 120px;
			background: var(--deep-space-blue);
		}
		.event-image-link:hover {
			opacity: 0.9;
			transform: translateY(-2px);
		}
		.event-image-link img {
			display: block;
			width: 100%;
			height: 100%;
			object-fit: cover;
			border-radius: 8px;
		}
		.calendar-cell {
			border-radius: 8px;
			overflow: hidden;
			border: 2px solid var(--sky-surge);
			box-shadow: 0 4px 12px rgba(1, 47, 64, 0.1);
			background: var(--white);
			height: 600px;
		}
		.calendar-cell iframe {
			width: 100%;
			height: 100%;
			border: none;
			display: block;
		}
		@media (max-width: 600px) {
			.events-grid { grid-template-columns: 1fr; }
			.calendar-cell { height: 500px; }
		}
		/* Connect */
		.connect-item {
			margin: 1.5em 0;
			text-align: center;
		}
		.connect-item h3 {
			font-size: 1.1em !important;
			text-align: center !important;
			margin: 0 0 0.4em;
			color: var(--deep-space-blue);
			font-weight: 700;
		}
		.connect-item p {
			margin: 0 0 1em;
			color: var(--deep-space-blue);
		}
		.instagram-embed {
			border-radius: 8px;
			overflow: hidden;
			border: 2px solid var(--sky-surge);
		}
		.instagram-embed iframe {
			width: 100%;
			height: 400px;
			border: none;
			display: block;
		}
		/* Blog */
		.blog-section {
			text-align: center;
		}
		.expand-button {
			display: block;
			width: 100%;
			padding: 0.9em 1.8em;
			background: var(--deep-space-blue);
			color: var(--white);
			border: 2px solid var(--sky-surge);
			border-radius: 6px;
			font-weight: 700;
			font-size: 1em;
			cursor: pointer;
			box-shadow: 0 4px 0 var(--sky-surge);
			transition: background 0.2s, box-shadow 0.2s, color 0.2s;
			margin: 0.5em 0;
		}
		.expand-button:hover {
			transform: translateY(-2px);
			box-shadow: 0 6px 0 var(--sky-surge);
		}
		.hidden-posts { display: none; }
		.hidden-posts.expanded { display: block; }
		.blog-list {
			display: flex;
			flex-wrap: wrap;
			gap: 1.5em;
			list-style: none;
			padding: 0;
			margin: 1em 0;
		}
		.blog-list li { width: calc(50% - 0.75em); }
		.blog-list li a { display: block; text-decoration: none; }
		.blog-list li img { width: 100%; border-radius: 8px; margin-bottom: 0.5em; }
		.blog-list .title { font-size: 0.95em; color: var(--deep-space-blue); margin: 0; line-height: 1.3; }
		.blog-list .date { font-size: 0.85em; color: var(--sky-surge); margin: 0.25em 0 0; }
		.blog-list li a:hover .title,
		.blog-list li a:hover .date { color: #7DD3F0; }
		@media (max-width: 600px) {
			.blog-list li { width: 100%; }
			.calendar-wrapper { padding-bottom: 100%; }
		}
		</style>
	</Fragment>

	<main>
		<Hero title="Join The Movement" subtitle="Stay connected with our events and activities" />
		<div class="content">

			<div class="buttons top-cta full-width">
				<a href="https://actionnetwork.org/forms/subscribe-to-emails-from-philly-jwj?source=direct_link&" target="_blank" rel="noopener noreferrer" class="btn">
					Subscribe to Emails
				</a>
			</div>

			<div class="buttons full-width" style="margin-bottom: 2em;">
				<a href="/hiring" class="btn btn-yellow">Get Paid to Build Working Class Power</a>
			</div>

			<h2>Become a Member</h2>
			<div class="buttons split-2">
				<a href="https://docs.google.com/forms/d/1OQLVSofjHVyG5FDtF6tlruzIfZhlXUChEvo-f8Z0qt8/viewform?edit_requested=true" target="_blank" rel="noopener noreferrer" class="btn">
					Individuals
				</a>
				<a href="/our-work/our-coalition" class="btn">
					Organizations
				</a>
			</div>

			<h2>Events</h2>
			<div class="events-grid">
				<a href="https://www.jwj.org/2026-national-conference-registration-now-open" target="_blank" rel="noopener noreferrer" class="event-image-link">
					<Image src={jwj2026Conference} alt="JWJ 2026 National Conference - Registration Now Open" />
				</a>
				<a href="https://www.lranetwork.org/news/lran-2026-conference-call-for-proposals/" target="_blank" rel="noopener noreferrer" class="event-link">
					Labor Research & Action Network 2026 Conference
					<span class="event-sub">Call for Proposals</span>
				</a>
				<a href="/our-work/power-school" class="event-link full-row">
					Power School
					<span class="event-sub">Organizer Training Program</span>
				</a>
				<div class="calendar-cell">
					<iframe
						src="https://calendar.google.com/calendar/embed?src=Y19lMDgzYWFmNDU3MDgzMDVjYjdhNDcxNzRmNWFiOGZjMGU0MjVjZDdhMzM1YWNmNDUxYmVkMjZjMzFjMzYwOTUzQGdyb3VwLmNhbGVuZGFyLmdvb2dsZS5jb20&ctz=America%2FNew_York"
						style="border: 0"
						frameborder="0"
						scrolling="no"
						title="Events Calendar">
					</iframe>
				</div>
			</div>

			<div class="connect-item">
				<div class="instagram-embed">
					<iframe
						src="https://www.instagram.com/phillyjobswithjustice/embed"
						width="100%"
						height="400"
						frameborder="0"
						scrolling="no"
						allowtransparency="true"
						title="Philadelphia Jobs with Justice Instagram Feed">
					</iframe>
				</div>
			</div>

			{posts.length > 0 && (
				<div class="blog-section">
					<button id="expand-button" class="expand-button">Show Blog Posts</button>
					<div id="hidden-posts" class="hidden-posts">
						<ul class="blog-list">
							{posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<Image width={720} height={360} src={post.data.heroImage} alt="" />
										)}
										<p class="title">{post.data.title}</p>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							))}
						</ul>
					</div>
				</div>
			)}

		</div>
	</main>

	<script>
		const expandButton = document.getElementById('expand-button');
		const hiddenPosts = document.getElementById('hidden-posts');

		if (expandButton && hiddenPosts) {
			expandButton.addEventListener('click', () => {
				const expanded = hiddenPosts.classList.toggle('expanded');
				expandButton.textContent = expanded ? 'Hide Blog Posts' : 'Show Blog Posts';
			});
		}
	</script>
</BaseLayout>
