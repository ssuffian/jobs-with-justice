---
import BaseHead from '../components/BaseHead.astro';
import ExpandableSection from '../components/ExpandableSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
import { fetchGoogleDocHtml, fetchHiringIndex } from '../lib/googleDoc';

const DOC_ID = '1u27odbxlQQYCCu3AnHy9XZoBnnG5MsupX9Kai79BMko';
const INDEX_TAB = 't.uje6zubnb332';

const positions = await fetchHiringIndex(DOC_ID, INDEX_TAB);
const positionContent = await Promise.all(
	positions.map(async (p) => ({
		...p,
		html: await fetchGoogleDocHtml(DOC_ID, p.tabId),
	}))
);
---

<BaseLayout>
	<Fragment slot="head">
		<BaseHead title={`Join Our Team - ${SITE_TITLE}`} description="Open positions at Philly Jobs With Justice. Apply for the People Power Fellowship or Roots to Power Internship — paid opportunities in Philadelphia." />
		<style>
			main h1 {
				font-size: 2em;
				text-align: center;
			}
			main h2 {
				font-size: 1.3em;
				text-align: left;
				margin-top: 0;
			}
			.intro {
				text-align: center;
				margin-bottom: 2em;
			}
			.position-header {
				margin-bottom: 1.5em;
			}
			.position-header h2 {
				margin-bottom: 0.25em;
			}
			.position-meta {
				font-size: 0.9em;
				color: #5a7a85;
			}
			.details-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0.4em 2em;
				margin: 0.5em 0;
			}
			.detail-item {
				display: flex;
				gap: 0.4em;
				font-size: 0.95em;
			}
			.detail-label {
				font-weight: 700;
				white-space: nowrap;
			}
			.apply-cta {
				text-align: center;
				margin-top: 1.25em;
				margin-bottom: 2em;
			}
			.apply-cta { margin-bottom: 2em; }
			.equal-opp {
				background: rgba(190, 202, 207, 0.15);
				border-left: 3px solid var(--sky-surge);
				padding: 1em 1.25em;
				border-radius: 0 6px 6px 0;
				margin-top: 1.5em;
				font-size: 0.95em;
				line-height: 1.7;
			}
			.equal-opp p { margin: 0; }
			@media (max-width: 600px) {
				.details-grid { grid-template-columns: 1fr; }
			}
		</style>
	</Fragment>
	<style is:global>
		.section-content h1, .section-content h2, .section-content h3,
		.section-content h4, .section-content h5, .section-content h6 {
			font-size: 1em;
			text-align: left;
			margin: 0.75em 0 0.25em;
		}
	</style>
	<main>
		<h1>Join Our Team</h1>
		<p class="intro">Working with us means joining a bold, coalition-driven effort that refuses to separate workers' rights from the broader social issues that shape our lives. We are radical in our vision, revolutionary in our approach, and grounded in the belief that real change happens when people come together across movements, industries, and communities. If you're driven to challenge the status quo, build collective power, and be part of something visionary and transformative, we want you on our team.</p>

		<p class="intro">Read more about our <a href="/about/mission_and_values">Mission and Values</a> and <a href="/about/history">learn about our history and impact</a>.</p>

		<div class="equal-opp">
			<p>Philly Jobs With Justice is committed to building a diverse and inclusive movement. We strongly encourage applications from people of color, immigrants, women, LGBTQ+ individuals, people from working-class backgrounds, and all those historically underrepresented in social justice work.</p>
		</div>

		<div class="apply-cta">
			<a href="https://forms.gle/1UaGYCEYTTy96YEZ7" target="_blank" rel="noopener noreferrer" class="site-btn site-btn--yellow">Apply Now!</a>
		</div>

		{positionContent.map((p) => (
			<ExpandableSection title={p.title} subtitle={`${p.timeFrame} · ${p.payment}`} color="blue">
				{p.html ? (
					<Fragment set:html={p.html} />
				) : (
					<p>Description unavailable. <a href={`https://docs.google.com/document/d/${DOC_ID}/edit?tab=${p.tabId}`} target="_blank" rel="noopener noreferrer">View on Google Docs</a>.</p>
				)}
			</ExpandableSection>
		))}
	</main>
</BaseLayout>
