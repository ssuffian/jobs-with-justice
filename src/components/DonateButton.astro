---
interface Props {
	text?: string;
	href?: string;
	size?: 'small' | 'medium' | 'large';
	variant?: 'primary' | 'secondary';
}

const { 
	text = 'Donate', 
	href = 'https://actionnetwork.org/fundraising/donate-to-philly-jwj-today?source=direct_link&',
	size = 'medium',
	variant = 'primary'
} = Astro.props;

const sizeClasses = {
	small: 'btn-small',
	medium: 'btn-medium',
	large: 'btn-large'
};

const variantClasses = {
	primary: 'btn-primary',
	secondary: 'btn-secondary'
};
---

<a href={href} target="_blank" rel="noopener noreferrer" class={`site-btn ${variant === 'primary' ? 'site-btn--yellow' : ''} ${sizeClasses[size]}`}>
	{text}
</a>

<style>
	/* Sizes — override the global site-btn padding/font-size */
	.btn-small {
		padding: 0.6em 1.4em;
		font-size: 0.95em;
	}
	.btn-medium {
		padding: 0.85em 1.8em;
		font-size: 1.05em;
	}
	.btn-large {
		padding: 1.1em 2.8em;
		font-size: 1.3em;
	}
</style>
